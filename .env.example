# ── Required on cloud platforms ─────────────────────────────────────────────
# Set this to your public domain if your platform doesn't auto-inject it.
# Examples:
#   PUBLIC_URL=https://smartshare.railway.app
#   PUBLIC_URL=https://smartshare.onrender.com
#   PUBLIC_URL=https://smartshare.fly.dev
#
# These platforms inject their URL automatically (no need to set PUBLIC_URL):
#   Railway   → RAILWAY_PUBLIC_DOMAIN
#   Render    → RENDER_EXTERNAL_URL
#   Fly.io    → FLY_APP_NAME
#   Heroku    → HEROKU_APP_DEFAULT_DOMAIN_NAME
#
# Leave blank for local development (uses LAN IP automatically).
PUBLIC_URL=

# Port (platforms set this automatically)
PORT=3000
